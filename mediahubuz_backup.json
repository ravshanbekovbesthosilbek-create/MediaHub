                console.error("GitHub-dan yuklashda xatolik:", error);
                // Agar internet bo'lmasa, mahalliy xotiradan yoki default-dan o'qiydi
                const localBackup = localStorage.getItem('media_movies');
                movies = localBackup ? JSON.parse(localBackup) : defaultMovies;
