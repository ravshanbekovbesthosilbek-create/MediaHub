            const y = document.getElementById('statYearly');
            const t = document.getElementById('statTotal');

            if(d) d.innerText = (platformTraffic.daily || 0).toLocaleString();
            if(m) m.innerText = (platformTraffic.monthly || 0).toLocaleString();
            if(y) y.innerText = (platformTraffic.yearly || 0).toLocaleString();
            if(t) t.innerText = (platformTraffic.lifetime || 0).toLocaleString();

            const ad = document.getElementById('admDailyViews');
            const am = document.getElementById('admMonthlyViews');
            const ay = document.getElementById('admYearlyViews');
            const at = document.getElementById('admTotalViews');

            if(ad) ad.innerText = (platformTraffic.daily || 0).toLocaleString();
            if(am) am.innerText = (platformTraffic.monthly || 0).toLocaleString();
            if(ay) ay.innerText = (platformTraffic.yearly || 0).toLocaleString();
