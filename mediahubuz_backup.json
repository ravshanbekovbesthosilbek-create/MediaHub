        function renderMovies(filter = "", year = "all") {
            const grid = document.getElementById('moviesGrid'); grid.innerHTML = '';
            let filtered = isSecretViewActive ? movies.filter(m => m.type === 'secret') : (currentTab === 'favorites' ? movies.filter(m => favorites.includes(String(m.code))) : movies.filter(m => m.type === currentTab));
            
            if(filter && !isSecretViewActive) filtered = filtered.filter(m => m.title.toLowerCase().includes(filter) || String(m.code) === filter);
            if(year !== "all" && !isSecretViewActive && currentTab !== 'favorites') filtered = filtered.filter(m => String(m.year) === year);

            if(filtered.length === 0) {
                grid.innerHTML = `<div class="col-span-full py-12 text-center text-xs text-zinc-500 uppercase tracking-widest">Kontent topilmadi yoki ro'yxat bo'sh...</div>`;
                return;
            }

            filtered.forEach((movie) => {
                const rating = calculateAverageRating(movie);
                grid.innerHTML += `
                    <div class="bg-zinc-900/40 backdrop-blur-md rounded-2xl overflow-hidden border border-zinc-800 flex flex-col justify-between hover:border-amber-500 hover:scale-[1.02] transition duration-300 shadow-2xl relative group ${movie.isPaused ? 'opacity-40' : ''}">
                        <div onclick="openDetailsModal('${movie.code}')" class="cursor-pointer relative aspect-[3/4]">
                            <img src="${movie.image || 'https://images.unsplash.com/photo-1509248961158-e54f6934749c?q=80&w=300'}" class="w-full h-full object-cover group-hover:brightness-90 transition" alt="${movie.title}">
                            <span class="absolute top-2 left-2 bg-black/85 text-amber-400 text-[9px] px-2 py-0.5 rounded-md font-black tracking-wider">${movie.isPaused ? 'BLOKLANGAN' : 'PREMIUM HD'}</span>
                            <span class="absolute top-2 right-2 bg-black/85 text-amber-400 text-[9px] px-1.5 py-0.5 rounded-md font-mono">⭐ ${rating}</span>
                        </div>
                        <div class="p-3 text-center bg-gradient-to-b from-transparent to-zinc-950">
                            <h3 class="font-bold text-xs uppercase truncate text-zinc-200 mb-2">${movie.title}</h3>
                            <button onclick="openDetailsModal('${movie.code}')" class="w-full bg-zinc-900 border border-zinc-800 text-amber-400 py-2 rounded-xl text-[10px] font-black uppercase hover:bg-amber-500 hover:text-black transition tracking-wider">${movie.isPaused ? 'Yopiq' : 'Tomosha Qilish'}</button>
                        </div>
                    </div>`;
            });
        }

        function renderCarousel() {
            const container = document.getElementById('carouselContainer'); container.innerHTML = '';
