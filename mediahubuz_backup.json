            }
        }

        function validateTimePeriods() {
            const now = new Date();
            let currentDay = now.getDate();
            let currentMonth = now.getMonth();
            let currentYear = now.getFullYear();
            let stateChanged = false;

            if(!platformTraffic.hasOwnProperty('daily')) platformTraffic.daily = 0;
            if(!platformTraffic.hasOwnProperty('monthly')) platformTraffic.monthly = 0;
            if(!platformTraffic.hasOwnProperty('yearly')) platformTraffic.yearly = 0;

            if (platformTraffic.lastLoggedDay !== currentDay) {
                platformTraffic.daily = 0;
                platformTraffic.lastLoggedDay = currentDay;
                stateChanged = true;
            }
            if (platformTraffic.lastLoggedMonth !== currentMonth) {
                platformTraffic.monthly = 0;
                platformTraffic.lastLoggedMonth = currentMonth;
                stateChanged = true;
            }
            if (platformTraffic.lastLoggedYear !== currentYear) {
                platformTraffic.yearly = 0;
                platformTraffic.lastLoggedYear = currentYear;
                stateChanged = true;
            }

            if(stateChanged) {
                localStorage.setItem('platform_traffic', JSON.stringify(platformTraffic));
            }
        }

        function runStatisticsSimulation() {
            syncGlobalTrafficUI();

            setInterval(() => {
                let step = Math.floor(1 + Math.random() * 5);
                if (liveTrendGoingUp) {
                    currentLiveUsers += step;
                    if (currentLiveUsers >= 200) {
                        currentLiveUsers = 200;
                        liveTrendGoingUp = false;
                    }
                } else {
                    currentLiveUsers -= step;
                    if (currentLiveUsers <= 50) {
                        currentLiveUsers = 50;
                        liveTrendGoingUp = true;
                    }
                }
                const liveUsersCountEl = document.getElementById('liveUsersCount');
                if(liveUsersCountEl) liveUsersCountEl.innerText = currentLiveUsers;
            }, 4000);

            setInterval(() => {
                validateTimePeriods();
                if(Math.random() > 0.4) { 
                    let growth = Math.floor(1 + Math.random() * 3);
                    incrementGlobalTraffic(growth);
                }
            }, 60000);
        }

        function incrementGlobalTraffic(amount = 1) {
            validateTimePeriods();
            platformTraffic.lifetime += amount;
            platformTraffic.daily += amount;
            platformTraffic.monthly += amount;
            platformTraffic.yearly += amount;
            localStorage.setItem('platform_traffic', JSON.stringify(platformTraffic));
            syncGlobalTrafficUI();
        }

