        function launchPlayerFromModal() {
            if(!selectedMovieGlobal) return;
            if(!selectedMovieGlobal.video) return showToast("Video oqimi mavjud emas!", "error");

            if (marketing.forcedVideo && marketing.adStatus !== 'paused' && !isSecretViewActive) {
                triggerForcedAdPipeline(() => { executeCorePlayerInitialization(); });
            } else {
                executeCorePlayerInitialization();
            }
        }

        function triggerForcedAdPipeline(callback) {
            const modal = document.getElementById('forcedAdModal');
            const adVideo = document.getElementById('forcedAdVideoComponent');
            const adImage = document.getElementById('forcedAdImageComponent');
            const feedback = document.getElementById('adTimerFeedback');
            const skipBtn = document.getElementById('skipAdActionButton');

            modal.classList.replace('hidden', 'flex');
            skipBtn.disabled = true;
            skipBtn.className = "bg-zinc-800 text-zinc-500 text-xs font-black px-4 py-2 rounded-xl uppercase transition cursor-not-allowed";
            
            let remaining = marketing.forcedDuration || 10;
            feedback.innerText = `Reklama tugashiga: ${remaining} soniya qoldi`;

            window.forcedAdCallbackToken = callback;

            if (marketing.forcedVideo.match(/\.(jpeg|jpg|gif|png|webp)/i) || marketing.forcedVideo.startsWith('data:image') || marketing.forcedVideo.startsWith('blob:')) {
                adVideo.classList.add('hidden');
                adImage.classList.remove('hidden');
                adImage.src = marketing.forcedVideo;
                adImage.onclick = () => { if(marketing.adRedirect) window.open(marketing.adRedirect, '_blank'); };
            } else {
                adImage.classList.add('hidden');
                adVideo.classList.remove('hidden');
                adVideo.src = marketing.forcedVideo;
                adVideo.onclick = () => { if(marketing.adRedirect) window.open(marketing.adRedirect, '_blank'); };
                adVideo.load();
                adVideo.play().catch(() => {});
            }

            if(window.forcedAdInterval) clearInterval(window.forcedAdInterval);
            
            window.forcedAdInterval = setInterval(() => {
                remaining--;
                if (remaining <= 0) {
                    clearInterval(window.forcedAdInterval);
                    feedback.innerText = "Siz reklamani o'tkazib yuborishingiz mumkin!";
                    skipBtn.disabled = false;
                    skipBtn.className = "bg-amber-500 text-black text-xs font-black px-4 py-2 rounded-xl uppercase transition cursor-pointer";
                } else {
                    feedback.innerText = `Reklama tugashiga: ${remaining} soniya qoldi`;
                }
            }, 1000);
        }

        function skipForcedAdAction() {
            if(window.forcedAdInterval) clearInterval(window.forcedAdInterval);
            document.getElementById('forcedAdVideoComponent').pause();
            document.getElementById('forcedAdModal').classList.replace('flex', 'hidden');
            if (window.forcedAdCallbackToken) { window.forcedAdCallbackToken(); window.forcedAdCallbackToken = null; }
        }

        function executeCorePlayerInitialization() {
            document.getElementById('modalPosterImg').classList.add('hidden');
            document.getElementById('videoPlayerWrapper').classList.remove('hidden');
            document.getElementById('toggleTheaterBtn').classList.remove('hidden');
            
            const p = document.getElementById('mainVideoPlayer');
            p.src = selectedMovieGlobal.video; 
            const savedTime = playbackHistory[selectedMovieGlobal.code];
            p.load();
            
            p.play().then(() => {
                if(savedTime && savedTime > 2) { 
                    if(confirm(`Siz ushbu videoni oxirgi marta ${Math.floor(savedTime / 60)} daqiqada tark etgansiz. Davom ettirilsinmi?`)) { 
                        p.currentTime = savedTime; 
                    }
                }
            }).catch(() => {
                showToast("Oqim tayyorlandi. Tizim ishga tushishi uchun PLAY bosing.", "info");
            });
        }

        function setupCustomPlayerCoreListeners() {
            const p = document.getElementById('mainVideoPlayer');
            const progress = document.getElementById('playerProgressBar');
            const timeDisplay = document.getElementById('playerTimeDisplay');
            const playBtn = document.getElementById('customPlayBtn');
            const loader = document.getElementById('playerBufferingLoader');

            p.addEventListener('timeupdate', () => {
                if(p.duration) {
                    progress.value = (p.currentTime / p.duration) * 100;
                    timeDisplay.innerText = `${formatTime(p.currentTime)} / ${formatTime(p.duration)}`;
                }
            });

            p.addEventListener('waiting', () => { if(loader) loader.classList.remove('hidden'); });
            p.addEventListener('playing', () => { if(loader) loader.classList.add('hidden'); });

            p.addEventListener('play', () => { if(playBtn) playBtn.innerText = "PAUSE"; });
            p.addEventListener('pause', () => { if(playBtn) playBtn.innerText = "PLAY"; });
        }

        function setupKeyboardControls() {
            window.addEventListener('keydown', (e) => {
                if(document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'TEXTAREA' || document.activeElement.tagName === 'SELECT') return;

                const p = document.getElementById('mainVideoPlayer');
                const wrapper = document.getElementById('videoPlayerWrapper');
                if(wrapper && !wrapper.classList.contains('hidden') && p) {
                    if(e.code === 'Space') {
                        e.preventDefault();
                        togglePlayPause();
                    } else if(e.code === 'ArrowRight') {
                        e.preventDefault();
                        p.currentTime = Math.min(p.duration, p.currentTime + 10);
                        showGestureFeedback("⏩ +10s Oldinga");
                    } else if(e.code === 'ArrowLeft') {
                        e.preventDefault();
                        p.currentTime = Math.max(0, p.currentTime - 10);
                        showGestureFeedback("⏪ -10s Orqaga");
                    } else if(e.code === 'ArrowUp') {
                        e.preventDefault();
                        p.volume = Math.min(1, p.volume + 0.1);
                        showGestureFeedback(`🔊 Ovoz: ${Math.round(p.volume * 100)}%`);
                    } else if(e.code === 'ArrowDown') {
                        e.preventDefault();
                        p.volume = Math.max(0, p.volume - 0.1);
                        showGestureFeedback(`🔊 Ovoz: ${Math.round(p.volume * 100)}%`);
                    }
                }
            });
        }

        function showGestureFeedback(text) {
            const feedback = document.getElementById('gestureFeedback');
            if(feedback) {
                feedback.innerText = text; feedback.style.opacity = '1';
                setTimeout(() => { feedback.style.opacity = '0'; }, 800);
            }
        }

        function togglePlayPause() {
            const p = document.getElementById('mainVideoPlayer');
            if(p.paused) p.play().catch(()=>{}); else p.pause();
        }

        function seekVideo(val) {
            const p = document.getElementById('mainVideoPlayer');
            if(p.duration) p.currentTime = (val / 100) * p.duration;
        }

        function changePlayerSpeed(speed) {
            document.getElementById('mainVideoPlayer').playbackRate = parseFloat(speed);
        }

        function simulateQualitySwitch(quality) {
            showToast(`Sifat: ${quality}...`, "info");
            const p = document.getElementById('mainVideoPlayer');
            const sec = p.currentTime;
            const isPaused = p.paused;
            setTimeout(() => { p.currentTime = sec; if(!isPaused) p.play().catch(()=>{}); }, 500);
        }

        function toggleFullScreen() {
            const wrap = document.getElementById('videoPlayerWrapper');
            if(!document.fullscreenElement) {
                wrap.requestFullscreen().catch(() => showToast("Fullscreen xatoligi", "error"));
            } else { document.exitFullscreen(); }
        }

        function setupPlayerTouchGesturesEngine() {
            const player = document.getElementById('mainVideoPlayer');
            
            document.getElementById('playerZoneLeft').addEventListener('dblclick', () => { player.currentTime = Math.max(0, player.currentTime - 10); showGestureFeedback("⏪ 10s Orqaga"); });
            document.getElementById('playerZoneRight').addEventListener('dblclick', () => { player.currentTime = Math.min(player.duration, player.currentTime + 10); showGestureFeedback("⏩ 10s Oldinga"); });
            document.getElementById('playerZoneCenter').addEventListener('dblclick', () => { togglePlayPause(); });

            let touchStartX = 0; let touchStartY = 0;
            const zoneLeft = document.getElementById('playerZoneLeft');
            const zoneRight = document.getElementById('playerZoneRight');

            zoneRight.addEventListener('touchstart', e => { touchStartY = e.touches[0].clientY; touchStartX = e.touches[0].clientX; }, {passive: true});
            zoneRight.addEventListener('touchmove', e => {
                let deltaY = touchStartY - e.touches[0].clientY;
                let deltaX = e.touches[0].clientX - touchStartX;
                if(Math.abs(deltaY) > Math.abs(deltaX) && Math.abs(deltaY) > 30) {
                    if(deltaY > 0) player.volume = Math.min(1, player.volume + 0.05);
                    else player.volume = Math.max(0, player.volume - 0.05);
                    showGestureFeedback(`🔊 Ovoz: ${Math.round(player.volume * 100)}%`);
                    touchStartY = e.touches[0].clientY;
                }
            }, {passive: true});

            zoneLeft.addEventListener('touchstart', e => { touchStartX = e.touches[0].clientX; }, {passive: true});
            zoneLeft.addEventListener('touchmove', e => {
                let deltaX = e.touches[0].clientX - touchStartX;
                if(Math.abs(deltaX) > 50) {
                    if(deltaX > 0) { player.currentTime = Math.min(player.duration, player.currentTime + 5); showGestureFeedback("⏩ Tezlashtirish +5s"); }
                    else { player.currentTime = Math.max(0, player.currentTime - 5); showGestureFeedback("⏪ Orqaga -5s"); }
                    touchStartX = e.touches[0].clientX;
                }
            }, {passive: true});
        }

        function toggleTheaterMode() {
            theaterMode = !theaterMode;
            const container = document.getElementById('modalLayoutContainer');
            const mediaBox = document.getElementById('modalMediaContainer');
            if(theaterMode) {
                container.classList.replace('max-w-5xl', 'max-w-full');
                mediaBox.classList.add('theater-mode-active');
                document.getElementById('toggleTheaterBtn').innerText = "🔲 Oddiy Rejim";
            } else {
                container.classList.replace('max-w-full', 'max-w-5xl');
                mediaBox.classList.remove('theater-mode-active');
                document.getElementById('toggleTheaterBtn').innerText = "🎭 Teatr Rejimi";
            }
        }

        function updateVotingUI() {
            if(!selectedMovieGlobal) return;
            const l = selectedMovieGlobal.likes || 0;
            const d = selectedMovieGlobal.dislikes || 0;
            document.getElementById('voteLikeCount').innerText = l;
            document.getElementById('voteDislikeCount').innerText = d;
            
            const total = l + d;
            const likePct = total > 0 ? Math.round((l / total) * 100) : 50;
            const dislikePct = total > 0 ? 100 - likePct : 50;
            
            document.getElementById('voteRatioText').innerText = `Ratio: ${likePct}% / ${dislikePct}%`;
            document.getElementById('voteRatioProgress').style.width = `${likePct}%`;
        }

        function castVote(type) {
            if(!selectedMovieGlobal) return;
            const code = selectedMovieGlobal.code;
            if(userVotedMatrix[code]) return showToast("Siz ushbu materialga ovoz berib bo'lgansiz!", "error");
            
            if(!selectedMovieGlobal.likes) selectedMovieGlobal.likes = 0;
            if(!selectedMovieGlobal.dislikes) selectedMovieGlobal.dislikes = 0;

            if(type === 'like') selectedMovieGlobal.likes += 1;
            else selectedMovieGlobal.dislikes += 1;

            userVotedMatrix[code] = type;
            localStorage.setItem('user_voted_matrix', JSON.stringify(userVotedMatrix));
            
            syncMovieToStorageArray(selectedMovieGlobal);
            updateVotingUI();
            showToast("Ovozingiz muvaffaqiyatli qabul qilindi.", "success");
        }

        function syncMovieToStorageArray(m) {
            const idx = movies.findIndex(mov => String(mov.code) === String(m.code));
            if(idx !== -1) { 
                movies[idx] = m; 
                localStorage.setItem('media_movies', JSON.stringify(movies)); 
            }
        }

        function handleCommentImageUpload(input) {
            const file = input.files[0];
            if(file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    temporaryCommentImgBase64 = e.target.result;
                    document.getElementById('commentImagePreview').src = temporaryCommentImgBase64;
                    document.getElementById('commentImagePreviewWrapper').classList.remove('hidden');
                };
                reader.readAsDataURL(file);
            }
        }

        function clearCommentImage() {
            temporaryCommentImgBase64 = null;
            document.getElementById('commentImageFile').value = '';
            document.getElementById('commentImagePreviewWrapper').classList.add('hidden');
        }

        function submitUserReview() {
            if(!selectedMovieGlobal) return;
            const name = document.getElementById('reviewerName').value.trim() || "Anonim";
            const rating = parseInt(document.getElementById('reviewerRating').value);
            const text = document.getElementById('reviewerText').value.trim();

            if(!text) return showToast("Fikr matnini yozing!", "error");
            if(!selectedMovieGlobal.reviews) selectedMovieGlobal.reviews = [];

            if(activeReplyTargetCommentId !== null) {
                findAndAppendReplyNode(selectedMovieGlobal.reviews, activeReplyTargetCommentId, name, text);
                showToast("Javobingiz chop etildi", "success");
            } else {
                const newComment = {
                    id: Date.now(),
                    name, rating, text,
                    img: temporaryCommentImgBase64,
                    likes: 0, replies: []
                };
                selectedMovieGlobal.reviews.push(newComment);
                showToast("Sharh qo'shildi", "success");
            }

            syncMovieToStorageArray(selectedMovieGlobal);
            document.getElementById('reviewerText').value = '';
            clearCommentImage();
            cancelReplyMode();
            renderReviews();
            updateComputedRatingBadge();
            renderMovies();
        }

        function findAndAppendReplyNode(arr, targetId, name, text) {
            for(let i=0; i<arr.length; i++) {
                if(arr[i].id === targetId) {
                    if(!arr[i].replies) arr[i].replies = [];
                    arr[i].replies.push({ id: Date.now(), name, text, likes: 0 });
                    return true;
                }
                if(arr[i].replies && arr[i].replies.length > 0) {
                    let found = findAndAppendReplyNode(arr[i].replies, targetId, name, text);
                    if(found) return true;
                }
            }
            return false;
        }

        function initReplyMode(commentId, authorName) {
            activeReplyTargetCommentId = commentId;
            document.getElementById('replyBadgeText').innerText = `⚡ ${authorName} sharhiga javob yozish:`;
            document.getElementById('replyBadge').classList.remove('hidden');
            document.getElementById('reviewerText').focus();
        }

        function cancelReplyMode() {
            activeReplyTargetCommentId = null;
            document.getElementById('replyBadge').classList.add('hidden');
        }

        function voteComment(commentId) {
            if(commentVotedMatrix[commentId]) return showToast("Faqat 1 marta bosish mumkin", "info");
            
            let incremented = modifyCommentLikeCounter(selectedMovieGlobal.reviews, commentId);
            if(incremented) {
                commentVotedMatrix[commentId] = true;
                localStorage.setItem('comment_voted_matrix', JSON.stringify(commentVotedMatrix));
                syncMovieToStorageArray(selectedMovieGlobal);
                renderReviews();
            }
        }

        function modifyCommentLikeCounter(arr, targetId) {
            for(let i=0; i<arr.length; i++) {
                if(arr[i].id === targetId) { arr[i].likes = (arr[i].likes || 0) + 1; return true; }
                if(arr[i].replies && arr[i].replies.length > 0) {
                    let res = modifyCommentLikeCounter(arr[i].replies, targetId); if(res) return true;
                }
            }
            return false;
        }

        function renderReviews() {
            const container = document.getElementById('reviewsContainer'); container.innerHTML = '';
            if(!selectedMovieGlobal.reviews || selectedMovieGlobal.reviews.length === 0) {
                container.innerHTML = `<div class="text-zinc-600 text-center py-2">Hozircha izohlar yo'q...</div>`; return;
            }
            container.innerHTML = buildNestedCommentTreeHTML(selectedMovieGlobal.reviews);
        }

        function buildNestedCommentTreeHTML(commentsArr, isReplyNode = false) {
            let html = '';
            commentsArr.forEach(c => {
                let starBadge = c.rating ? '⭐'.repeat(c.rating) : '';
                let imgHtml = c.img ? `<img src="${c.img}" class="mt-2 rounded-xl max-h-32 object-contain border border-zinc-800" alt="Comment media">` : '';
                let likeBtn = ` <button onclick="voteComment(${c.id})" class="text-zinc-500 hover:text-emerald-400">👍 ${c.likes || 0}</button>`;
                let replyBtn = !isReplyNode ? `• <button onclick="initReplyMode(${c.id}, '${c.name}')" class="text-zinc-500 hover:text-amber-400">Javob berish</button>` : '';

                html += `
                    <div class="${isReplyNode ? 'reply-box mt-2 bg-zinc-950/40' : 'bg-zinc-900/60'} p-2.5 rounded-xl border border-zinc-800/60">
                        <div class="flex justify-between font-bold text-zinc-300 text-[10px] mb-1">
                            <span>⚡ ${c.name}</span>
                            <span class="text-amber-400 font-mono">${starBadge}</span>
                        </div>
                        <p class="text-zinc-400 text-xs leading-relaxed">${c.text}</p>
                        ${imgHtml}
                        <div class="text-[9px] mt-2 space-x-2 font-black uppercase text-zinc-600">
                            ${likeBtn} ${replyBtn}
                        </div>
                        ${c.replies && c.replies.length > 0 ? buildNestedCommentTreeHTML(c.replies, true) : ''}
                    </div>`;
            });
            return html;
        }

        function calculateAverageRating(movie) {
            if(!movie.reviews || movie.reviews.length === 0) return "5.0";
            let totalStars = 0; let rootCommentsCount = 0;
            movie.reviews.forEach(r => { if(r.rating) { totalStars += r.rating; rootCommentsCount++; } });
            return rootCommentsCount > 0 ? (totalStars / rootCommentsCount).toFixed(1) : "5.0";
        }

        function updateComputedRatingBadge() {
            if(selectedMovieGlobal) document.getElementById('computedRatingValue').innerText = calculateAverageRating(selectedMovieGlobal);
        }

        function toggleFavoriteAction() {
            if(!selectedMovieGlobal) return;
            const code = String(selectedMovieGlobal.code);
            const idx = favorites.indexOf(code);
            if(idx === -1) { favorites.push(code); showToast("Sevimli ro'yxatingizga qo'shildi.", "success"); }
            else { favorites.splice(idx, 1); showToast("Sevimli ro'yxatdan olib tashlandi.", "info"); }
            localStorage.setItem('media_favorites', JSON.stringify(favorites));
            updateFavoriteButtonUI();
        }

        function updateFavoriteButtonUI() {
            if(!selectedMovieGlobal) return;
            const btn = document.getElementById('favoriteToggleBtn');
            if(!btn) return;
            if(favorites.includes(String(selectedMovieGlobal.code))) {
                btn.className = "bg-red-600 text-white px-4 rounded-xl transition flex items-center justify-center text-lg";
            } else {
                btn.className = "bg-zinc-900 border border-zinc-800 hover:border-red-500 text-red-500 px-4 rounded-xl transition flex items-center justify-center text-lg";
            }
        }

        function processAndAddMovie() {
            const type = document.getElementById('movieType').value;
            const title = document.getElementById('movieTitle').value.trim();
            const code = document.getElementById('movieCode').value.trim();
            const year = document.getElementById('movieYear').value.trim() || "Ixtiyoriy";
            const genre = document.getElementById('movieGenre').value.trim() || "Ixtiyoriy";
            const desc = document.getElementById('movieDesc').value.trim() || "Ma'lumot kiritilmagan.";
            const tgLink = document.getElementById('movieTgLink').value.trim() || "https://t.me/MediaHub_Uz_bot";
            const image = document.getElementById('movieImgLink').value.trim() || "";
            const video = document.getElementById('movieVideoLink').value.trim() || "";
            const trailerLink = document.getElementById('movieTrailerLink').value.trim() || "";
            
            const lOverride = parseInt(document.getElementById('movieLikesOverride').value) || 0;
            const dOverride = parseInt(document.getElementById('movieDislikesOverride').value) || 0;
            const vOverride = parseInt(document.getElementById('movieViewsOverride').value) || 0;

            if(!title || !code) return showToast("Sarlavha va Unikal Kod majburiy hisoblanadi!", "error");

            if(editTargetCode !== null) {
                let idx = movies.findIndex(m => String(m.code) === String(editTargetCode));
                if(idx !== -1) {
                    movies[idx].type = type; movies[idx].title = title; movies[idx].code = code;
                    movies[idx].year = year; movies[idx].genre = genre; movies[idx].desc = desc;
                    movies[idx].image = image; movies[idx].video = video; movies[idx].trailerLink = trailerLink;
                    movies[idx].tgLink = tgLink; movies[idx].likes = lOverride; movies[idx].dislikes = dOverride;
                    movies[idx].views = vOverride;
                }
                editTargetCode = null; showToast("Material muvaffaqiyatli yangilandi.", "success");
            } else {
                if(movies.some(m => String(m.code) === String(code))) return showToast("Ushbu unikal kod bazada mavjud!", "error");
                movies.push({ type, title, code, year, genre, desc, image, video, trailerLink, tgLink, likes: lOverride, dislikes: dOverride, views: vOverride, isPaused: false, reviews: [] });
                showToast("Yangi resurs muvaffaqiyatli saqlandi.", "success");
            }

            localStorage.setItem('media_movies', JSON.stringify(movies));
            resetAdminForm(); refreshAdminDashboard(); renderMovies(); renderCarousel();
        }

        function refreshAdminDashboard() {
            const list = document.getElementById('adminMoviesList'); if(!list) return;
            list.innerHTML = '';
            movies.forEach(m => {
                let pauseBtnText = m.isPaused ? "▶️ Unpause" : "⏸️ Pause";
                list.innerHTML += `
                    <div class="admin-item bg-zinc-950 p-2.5 rounded-xl border border-zinc-900 flex justify-between items-center text-[11px]" data-title="${m.title.toLowerCase()}" data-code="${m.code}">
                        <div class="truncate max-w-[140px]"><b>[${m.type.toUpperCase()}]</b> ${m.title}</div>
                        <div class="flex gap-2 shrink-0 text-[10px]">
                            <button onclick="toggleAdminMediaStreamState('${m.code}')" class="text-blue-400 font-bold">${pauseBtnText}</button>
                            <button onclick="startEditMovie('${m.code}')" class="text-amber-500 font-bold hover:underline">Edit</button>
                            <button onclick="adminDeleteMovie('${m.code}')" class="text-red-500 font-bold hover:underline">O'chirish</button>
                        </div>
                    </div>`;
            });
        }

        function toggleAdminMediaStreamState(code) {
            let idx = movies.findIndex(m => String(m.code) === String(code));
            if(idx !== -1) {
                movies[idx].isPaused = !movies[idx].isPaused;
                localStorage.setItem('media_movies', JSON.stringify(movies));
                refreshAdminDashboard(); renderMovies();
                showToast(`Media oqimi holati o'zgartirildi`, "info");
            }
        }

        function startEditMovie(code) {
            const m = movies.find(mov => String(mov.code) === String(code));
            if(!m) return;
            editTargetCode = code;
            document.getElementById('movieType').value = m.type;
            document.getElementById('movieTitle').value = m.title;
            document.getElementById('movieCode').value = m.code;
            document.getElementById('movieYear').value = m.year === "Ixtiyoriy" ? "" : m.year;
            document.getElementById('movieGenre').value = m.genre === "Ixtiyoriy" ? "" : m.genre;
            document.getElementById('movieDesc').value = m.desc === "Ma'lumot kiritilmagan." ? "" : m.desc;
            document.getElementById('movieImgLink').value = m.image || "";
            document.getElementById('movieVideoLink').value = m.video || "";
            document.getElementById('movieTrailerLink').value = m.trailerLink || "";
            document.getElementById('movieTgLink').value = m.tgLink || "";
            document.getElementById('movieLikesOverride').value = m.likes || 0;
            document.getElementById('movieDislikesOverride').value = m.dislikes || 0;
            document.getElementById('movieViewsOverride').value = m.views || 0;
            
            document.getElementById('adminFormTitle').innerText = "📝 Tahrirlash Rejimi Faol";
            document.getElementById('adminSubmitBtn').innerText = "O'zgarishlarni Saqlash";
            document.getElementById('adminCancelEditBtn').classList.remove('hidden');

            renderAdminCommentModifierList(m);
        }

        function renderAdminCommentModifierList(movie) {
            const container = document.getElementById('adminReviewControlNode');
            if(!container) return;
            container.innerHTML = `<h5 class="text-[10px] text-zinc-400 font-bold mb-2">"${movie.title}" sharhlari:</h5>`;
            if(!movie.reviews || movie.reviews.length === 0) {
                container.innerHTML += `<p class="text-zinc-600 py-2 text-center">Izohlar magjud emas.</p>`; return;
            }
            movie.reviews.forEach(r => {
                container.innerHTML += `
                    <div class="bg-zinc-900 p-1.5 rounded border border-zinc-800 flex justify-between items-center text-[10px]">
                        <div class="truncate pr-2"><b class="text-amber-500">${r.name}:</b> ${r.text}</div>
                        <button onclick="adminDeleteComment('${movie.code}', ${r.id})" class="text-red-500 font-bold shrink-0 hover:underline">O'chirish</button>
                    </div>`;
            });
        }

        function adminDeleteComment(movieCode, commentId) {
            let idx = movies.findIndex(m => String(m.code) === String(movieCode));
            if(idx !== -1) {
                movies[idx].reviews = movies[idx].reviews.filter(r => r.id !== commentId);
                localStorage.setItem('media_movies', JSON.stringify(movies));
                showToast("Sharh o'chirildi", "info");
                startEditMovie(movieCode);
                renderReviews();
            }
        }

        function cancelEditMode() { editTargetCode = null; resetAdminForm(); }

        function resetAdminForm() {
            document.getElementById('movieTitle').value = ''; document.getElementById('movieCode').value = '';
            document.getElementById('movieDesc').value = ''; document.getElementById('movieImgLink').value = '';
            document.getElementById('movieVideoLink').value = ''; document.getElementById('movieTrailerLink').value = '';
            document.getElementById('movieTgLink').value = ''; document.getElementById('movieLikesOverride').value = 0;
            document.getElementById('movieDislikesOverride').value = 0; document.getElementById('movieViewsOverride').value = 0;
            document.getElementById('adminFormTitle').innerText = "Multimedia Resurslarini Yuklash Ombori (CRUD)";
            document.getElementById('adminSubmitBtn').innerText = "Ma'lumotlar omboriga saqlash";
            document.getElementById('adminCancelEditBtn').classList.add('hidden');
            document.getElementById('adminReviewControlNode').innerHTML = `<p class="text-zinc-600 text-center py-4">Tahrirlash uchun yuqoridan materialni "Edit" bosing</p>`;
            document.getElementById('movieImgFile').value = '';
            document.getElementById('movieVideoFile').value = '';
            document.getElementById('movieTrailerFile').value = '';
        }

        function adminDeleteMovie(code) {
            if(confirm("Ushbu material butunlay o'chirilsinmi?")) {
                movies = movies.filter(m => String(m.code) !== String(code));
                localStorage.setItem('media_movies', JSON.stringify(movies));
                refreshAdminDashboard(); renderMovies(); renderCarousel();
                showToast("Resurs o'chirildi.", "info");
                cancelEditMode();
            }
        }

        function filterAdminContent() {
            const val = document.getElementById('adminContentSearch').value.toLowerCase();
            document.querySelectorAll('.admin-item').forEach(item => {
                if(item.getAttribute('data-title').includes(val) || String(item.getAttribute('data-code')).includes(val)) item.classList.remove('hidden');
                else item.classList.add('hidden');
            });
        }

        function exportData(type) {
            if(type === 'media') {
                const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(movies, null, 2));
                const downloadAnchor = document.createElement('a');
                downloadAnchor.setAttribute("href", dataStr); downloadAnchor.setAttribute("download", "mediahub_backup.json");
                document.body.appendChild(downloadAnchor); downloadAnchor.click(); downloadAnchor.remove();
            }
        }

        function importData(event) {
            const file = event.target.files[0]; if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const parsedData = JSON.parse(e.target.result);
                    if (Array.isArray(parsedData)) {
                        movies = parsedData; localStorage.setItem('media_movies', JSON.stringify(movies));
                        showToast("Baza muvaffaqiyatli import qilindi!", "success");
                        refreshAdminDashboard(); renderMovies(); renderCarousel();
                    }
                } catch (err) { showToast("JSON o'qishda xatolik.", "error"); }
            };
            reader.readAsText(file);
        }

        function formatTime(seconds) {
            if(isNaN(seconds)) return "00:00";
            let min = Math.floor(seconds / 60); let sec = Math.floor(seconds % 60);
            return (min < 10 ? "0" + min : min) + ":" + (sec < 10 ? "0" + sec : sec);
        }

        function exitAdminPanel() { window.location.hash = ''; syncMarketingUI(); }
    </script>
</body>
</html>
