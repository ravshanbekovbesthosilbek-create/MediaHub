                    <div onclick="openDetailsModal('${movie.code}')" class="min-w-[140px] bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden cursor-pointer shrink-0 hover:border-amber-500 hover:scale-95 transition duration-300 shadow-lg">
                        <img src="${movie.image || 'https://images.unsplash.com/photo-1509248961158-e54f6934749c?q=80&w=200'}" class="w-full h-24 object-cover" alt="${movie.title}">
                        <div class="p-2 text-[10px] truncate font-black text-center text-zinc-400 uppercase tracking-tight">${movie.title}</div>
                    </div>`;
            });
        }

        function openDetailsModal(code) {
            const m = movies.find(mov => String(mov.code) === String(code));
            if(!m) return;
            if(m.isPaused) return showToast("Ushbu material ma'muriyat tomonidan vaqtincha muzlatilgan!", "error");
            selectedMovieGlobal = m;

            if(!m.views) m.views = 0;
            m.views += 1;
            syncMovieToStorageArray(m);
            
            incrementGlobalTraffic(1);

            document.getElementById('modalTitle').innerText = m.title;
            document.getElementById('modalDesc').innerText = m.desc || "Ushbu kontent uchun batafsil tavsif kiritilmagan.";
            document.getElementById('modalPosterImg').src = m.image || 'https://images.unsplash.com/photo-1509248961158-e54f6934749c?q=80&w=400';
            document.getElementById('modalPosterImg').classList.remove('hidden');
            document.getElementById('videoPlayerWrapper').classList.add('hidden');
            document.getElementById('toggleTheaterBtn').classList.add('hidden');
            
            document.getElementById('modalCodeBadge').innerText = `KOD: ` + m.code + ` | 👁️ ` + (m.views || 1);
            document.getElementById('modalGenre').innerText = `${m.genre || 'Triller'} (${m.year || '2026'})`;
            document.getElementById('actionTrailerBtn').href = m.trailerLink || "https://youtube.com";
            
            if(m.tgLink) {
                let cleanLink = m.tgLink.split('?')[0];
                document.getElementById('actionTelegramBtn').href = `${cleanLink}?start=${m.code}`;
            } else {
                document.getElementById('actionTelegramBtn').href = `https://t.me/MediaHub_Uz_bot?start=${m.code}`;
            }

            if(playbackHistory[m.code] && playbackHistory[m.code] > 2) {
                document.getElementById('continueWatchingBadge').classList.remove('hidden');
            } else { document.getElementById('continueWatchingBadge').classList.add('hidden'); }

            cancelReplyMode();
            updateFavoriteButtonUI();
            updateVotingUI();
            renderReviews();
            updateComputedRatingBadge();

            document.getElementById('detailsModal').classList.replace('hidden', 'flex');
        }

        function closeDetailsModal() {
            const p = document.getElementById('mainVideoPlayer');
            if(selectedMovieGlobal && p.currentTime > 2 && p.currentTime < p.duration - 5) {
                playbackHistory[selectedMovieGlobal.code] = p.currentTime;
                localStorage.setItem('media_playback_history', JSON.stringify(playbackHistory));
            }
            p.pause();
            if(document.fullscreenElement) document.exitFullscreen().catch(()=>{});
            if(theaterMode) toggleTheaterMode();
            document.getElementById('detailsModal').classList.replace('flex', 'hidden');
            selectedMovieGlobal = null;
